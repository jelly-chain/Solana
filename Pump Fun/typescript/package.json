{
  "name": "@jellychain/pumpfun-sdk",
  "version": "1.0.0",
  "description": "JellyChain SDK for launching, buying back, locking, and claiming fees on Pump.fun (Solana)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "solana",
    "pump.fun",
    "pumpfun",
    "jellychain",
    "sdk",
    "defi",
    "token-launch",
    "meme-coin",
    "bonding-curve"
  ],
  "author": "JellyChain <https://github.com/jelly-chain>",
  "license": "MIT",
  "homepage": "https://jellychain.fun/docs",
  "repository": {
    "type": "git",
    "url": "https://github.com/jelly-chain/pumpfun-sdk"
  },
  "bugs": {
    "url": "https://github.com/jelly-chain/pumpfun-sdk/issues"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.0",
    "@solana/spl-token": "^0.4.6",
    "@solana/web3.js": "^1.95.3",
    "bs58": "^5.0.0",
    "pumpdotfun-sdk": "^1.3.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  },
  "peerDependencies": {
    "@solana/web3.js": "^1.95.3"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
